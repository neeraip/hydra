{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hydra",
  "version": "0.1.0",
  "identifier": "app.hydra",
  "build": {
    "frontendDist": "./frontend/dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": {
      "script": "pnpm run dev",
      "cwd": "./frontend"
    },
    "beforeBuildCommand": {
      "script": "pnpm run build",
      "cwd": "./frontend"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hydra",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "minWidth": 1024,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
